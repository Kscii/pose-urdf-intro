{
  "name": "pose-urdf-intro",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "slidev slides.md --open",
    "build": "slidev build slides.md",
    "build:pages": "slidev build slides.md --base /pose-urdf-intro/",
    "check:overflow": "npm run build && node scripts/check-slide-overflow.mjs",
    "export": "slidev export slides.md --output pose-urdf-intro.pdf"
  },
  "devDependencies": {
    "@slidev/cli": "52.17.0",
    "@slidev/parser": "52.17.0",
    "@slidev/theme-default": "0.25.0",
    "playwright-chromium": "^1.61.1"
  }
}
